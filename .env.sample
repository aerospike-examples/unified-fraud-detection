# Google ADK / Gemini configuration
# Get an API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
# Use the Gemini Developer API (not Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Investigation engine: adk (default) or langgraph
INVESTIGATION_ENGINE=adk

# LLM provider for both engines: gemini or ollama
LLM_PROVIDER=gemini

# Model the ADK / LangGraph agents use when LLM_PROVIDER=gemini
ADK_MODEL=gemini-3.1-flash-lite

# Ollama settings when LLM_PROVIDER=ollama (run Ollama on the host, not in compose)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
